{
  "name": "@taskmaster/db",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./migrations/*": "./dist/migrations/*.js"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "migrate:dev": "node --loader ts-node/register src/migrations/run.ts",
    "migrate": "node dist/migrations/run.js"
  },
  "dependencies": {
    "kysely": "^0.29.0",
    "better-sqlite3": "^12.0.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
