# This is the recommended environment variable template.
# Copy to .env and fill in your values.

# Application origin (used for CORS, OIDC redirect, etc.)
APP_ORIGIN=http://localhost:3000

# OIDC authentication (required for login)
OIDC_ISSUER=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# Database dialect (sqlite or postgres)
DB_DIALECT=sqlite

# SQLite database path (local or Docker)
# Docker default: /data/taskmaster.db
# Local default: /tmp/taskmaster.db
SQLITE_PATH=/tmp/taskmaster.db

# PostgreSQL connection string (if DB_DIALECT=postgres)
# DATABASE_URL=postgresql://username:password@host:5432/dbname

# OpenAI-compatible API for AI breakdown features
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Optional development auth bypass (only when NODE_ENV != production)
DEV_AUTH_BYPASS=bypass-token
